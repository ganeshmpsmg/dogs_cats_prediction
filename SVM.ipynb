import numpy as np
import matplotlib.pyplot as plt
import os
import random
from tensorflow.keras.preprocessing import image as kimage

# Image size used during training
IMG_SIZE = (128, 128)


# Function to predict image
def predict_image(img_path):
    img = kimage.load_img(img_path, target_size=IMG_SIZE)
    arr = kimage.img_to_array(img) / 255.0
    arr = np.expand_dims(arr, axis=0)

    prob = model.predict(arr)[0][0]

    label = "Dog" if prob > 0.5 else "Cat"
    conf = prob if prob > 0.5 else 1 - prob

    plt.imshow(img)
    plt.title(f"{label} ({conf:.1%} confidence)")
    plt.axis("off")
    plt.show()

    print(f"Prediction: {label} | Confidence: {conf:.4f}")


# Dataset main folder
folder = r"C:\Users\ganes\.cache\kagglehub\datasets\moazeldsokyx\dogs-vs-cats\versions\1"

# Check path
if not os.path.exists(folder):
    print("Dataset path not found!")
    exit()

# Collect images recursively
images = []

for root, dirs, files in os.walk(folder):
    for file in files:
        if file.lower().endswith((".jpg", ".jpeg", ".png")):
            images.append(os.path.join(root, file))

print("Total images found:", len(images))

# Safety check
if len(images) == 0:
    print("No images found. Check dataset structure.")
    exit()

# Select random image
img_path = random.choice(images)

print("Testing Image:", img_path)
from tensorflow.keras.models import load_model

model = load_model("dogs_vs_cats_model.keras")

# Predict
predict_image(img_path)
#%%
 # Save model
model.save("dogs_vs_cats_model.h5")
print("Model saved as dogs_vs_cats_model.keras")

